# editorconfig.org
root = true

# ========= Global settings ===========

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
indent_size = 2
trim_trailing_whitespace = false
insert_final_newline = false


# === Settings for all filetypes ======

[*.bat]
end_of_line = crlf

[*.go]
indent_style = tab

[*.{json,jsonc}]
indent_size = 4

[*.xml]
indent_size = 4

[*.{yaml,yml}]
indent_size = 2


# ======= Repo custom files ===========
